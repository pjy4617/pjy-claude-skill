    },
    "I2C3": {
      "bus": "APB1",
      "pins": {
        "SCL": ["PA8/AF4"],
        "SDA": ["PB4/AF9", "PC9/AF4"]
      },
      "_note": "F401의 I2C3_SDA PB4는 AF9 (F407은 I2C3_SDA=PC9/AF4만)"
    },
    "USART1": {
      "bus": "APB2",
      "pins": {
        "TX": ["PA9/AF7", "PB6/AF7"],
        "RX": ["PA10/AF7", "PB7/AF7"]
      }
    },
    "USART2": {
      "bus": "APB1",
      "pins": {
        "TX": ["PA2/AF7"],
        "RX": ["PA3/AF7"]
      }
    },
    "USART6": {
      "bus": "APB2",
      "pins": {
        "TX": ["PA11/AF8", "PC6/AF8"],
        "RX": ["PA12/AF8", "PC7/AF8"]
      },
      "_note": "PA11/PA12의 USART6는 F401 전용 매핑 (F407에서는 USB/CAN)"
    },
    "USB_OTG_FS": {
      "pins": {
        "DM":   ["PA11/AF10"],
        "DP":   ["PA12/AF10"],
        "VBUS": ["PA9/GPIO_INPUT"],
        "ID":   ["PA10/AF10"],
        "SOF":  ["PA8/AF10"]
      },
      "_warning": "PA11/PA12가 USART6와 공유 — USB와 USART6(PA11/PA12) 동시 사용 불가"
