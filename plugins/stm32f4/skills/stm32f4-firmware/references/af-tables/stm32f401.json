{
  "_comment": "STM32F401xx AF 매핑 — 공식 데이터시트 DS9716 Rev 5, Table 9 기준",
  "_datasheet": "DS9716",
  "_mcu": "STM32F401xx",
  "_packages": ["UFQFPN48", "LQFP48", "LQFP64", "UFBGA64"],
  "_sysclk_max": 84,
  "_flash_max": "512KB (F401xE), 256KB (F401xC)",
  "_sram": "96KB (xE), 64KB (xC), CCM 없음",

  "_missing_vs_f407": [
    "SPI3 없음 (AF6 미지원)",
    "USART3 없음",
