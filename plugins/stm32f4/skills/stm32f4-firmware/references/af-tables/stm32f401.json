    "CAN 없음",
    "DAC 없음",
    "USB_OTG_HS 없음",
    "Ethernet 없음",
    "FSMC 없음",
    "DCMI 없음",
    "SDIO 없음",
    "TIM6/TIM7/TIM8/TIM12/TIM13/TIM14 없음",
    "ADC2/ADC3 없음 (ADC1만)"
  ],

  "peripherals": {
    "SPI1": {
      "bus": "APB2",
      "pins": {
        "SCK":  ["PA5/AF5", "PB3/AF5"],
        "MISO": ["PA6/AF5", "PB4/AF5"],
        "MOSI": ["PA7/AF5", "PB5/AF5"],
        "NSS":  ["PA4/AF5", "PA15/AF5"]
      }
    },
    "SPI2": {
      "bus": "APB1",
      "pins": {
        "SCK":  ["PB10/AF5", "PB13/AF5"],
        "MISO": ["PB14/AF5", "PC2/AF5"],
        "MOSI": ["PB15/AF5", "PC3/AF5"],
        "NSS":  ["PB9/AF5", "PB12/AF5"]
      }
    },
    "SPI3": {
      "_note": "F401에는 SPI3 없음 — SPI4(AF5) 사용",
      "available": false
    },
    "SPI4": {
      "bus": "APB2",
      "pins": {
        "SCK":  ["PB13/AF6"],
        "MISO": ["PA11/AF6"],
        "MOSI": ["PA1/AF5"],
        "NSS":  ["PB12/AF6"]
      },
      "_note": "F401xD/xE에서만 사용 가능"
    },
    "I2C1": {
      "bus": "APB1",
      "pins": {
        "SCL": ["PB6/AF4", "PB8/AF4"],
        "SDA": ["PB7/AF4", "PB9/AF4"]
      }
    },
    "I2C2": {
      "bus": "APB1",
      "pins": {
        "SCL": ["PB10/AF4"],
        "SDA": ["PB3/AF9"]
      },
