{
  "_comment": "STM32F446xx AF 매핑 — 공식 데이터시트 DS10693 Rev 8, Table 11 기준",
  "_datasheet": "DS10693",
  "_mcu": "STM32F446xx",
  "_packages": ["LQFP64", "LQFP100", "LQFP144", "UFBGA144", "WLCSP81"],
  "_sysclk_max": 180,
  "_flash_max": "512KB",
  "_sram": "128KB, CCM 없음",

  "_differences_vs_f407": [
    "최대 클럭 180MHz (F407은 168MHz)",
    "SPI4 추가 (AF5)",
    "SAI1/SAI2 추가 (AF6)",
    "FMPI2C1 추가 (AF4) — Fast Mode Plus I2C",
    "QUADSPI 추가 (AF9/AF10)",
    "SPDIFRX 추가 (AF8)",
    "CEC (HDMI-CEC) 추가 (AF6)",
    "Ethernet 없음 (F407은 있음)",
    "DCMI 있음",
    "FSMC → FMC",
    "USB OTG HS 내장 PHY 미지원 (외부 ULPI 필요)",
    "CCM SRAM 없음"
  ],

  "peripherals": {
    "SPI1": {
      "bus": "APB2",
      "pins": {
        "SCK":  ["PA5/AF5", "PB3/AF5"],
        "MISO": ["PA6/AF5", "PB4/AF5"],
        "MOSI": ["PA7/AF5", "PB5/AF5"],
        "NSS":  ["PA4/AF5", "PA15/AF5"]
      }
    },
    "SPI2": {
      "bus": "APB1",
      "pins": {
        "SCK":  ["PA9/AF5", "PB10/AF5", "PB13/AF5", "PD3/AF5"],
        "MISO": ["PB14/AF5", "PC2/AF5"],
        "MOSI": ["PB15/AF5", "PC1/AF7", "PC3/AF5"],
        "NSS":  ["PB9/AF5", "PB12/AF5"]
      },
      "_note": "F446의 SPI2_SCK에 PA9/AF5 추가 (F407에는 없음)"
    },
    "SPI3": {
      "bus": "APB1",
      "pins": {
        "SCK":  ["PB3/AF6", "PC10/AF6"],
        "MISO": ["PB4/AF6", "PC11/AF6"],
        "MOSI": ["PB5/AF6", "PC12/AF6", "PD6/AF5"],
        "NSS":  ["PA4/AF6", "PA15/AF6"]
      }
    },
    "SPI4": {
      "bus": "APB2",
      "pins": {
        "SCK":  ["PE2/AF5", "PE12/AF5"],
        "MISO": ["PE5/AF5", "PE13/AF5"],
        "MOSI": ["PE6/AF5", "PE14/AF5"],
        "NSS":  ["PE4/AF5", "PE11/AF5"]
      }
    },
    "I2C1": {
      "bus": "APB1",
      "pins": {
        "SCL": ["PB6/AF4", "PB8/AF4"],
        "SDA": ["PB7/AF4", "PB9/AF4"]
      }
    },
    "I2C2": {
      "bus": "APB1",
      "pins": {
        "SCL": ["PB10/AF4", "PF1/AF4"],
        "SDA": ["PB11/AF4", "PF0/AF4", "PB3/AF4"]
      },
      "_note": "F446의 I2C2_SDA에 PB3/AF4 추가"
    },
    "I2C3": {
      "bus": "APB1",
      "pins": {
        "SCL": ["PA8/AF4"],
        "SDA": ["PC9/AF4", "PB4/AF4"]
      }
    },
    "FMPI2C1": {
      "bus": "APB1",
      "pins": {
        "SCL": ["PC6/AF4", "PD12/AF4", "PD14/AF4"],
        "SDA": ["PC7/AF4", "PD13/AF4", "PD15/AF4"]
      },
      "_note": "Fast Mode Plus I2C — 최대 1MHz, F446 전용"
    },
    "USART1": {
      "bus": "APB2",
      "pins": {
        "TX": ["PA9/AF7", "PB6/AF7"],
        "RX": ["PA10/AF7", "PB7/AF7"]
      }
    },
    "USART2": {
      "bus": "APB1",
      "pins": {
        "TX": ["PA2/AF7", "PD5/AF7"],
        "RX": ["PA3/AF7", "PD6/AF7"]
      }
    },
    "USART3": {
      "bus": "APB1",
      "pins": {
        "TX": ["PB10/AF7", "PC10/AF7", "PD8/AF7"],
        "RX": ["PB11/AF7", "PC5/AF7", "PC11/AF7", "PD9/AF7"]
      },
      "_note": "F446의 USART3_RX에 PC5/AF7 추가"
    },
    "UART4": {
      "bus": "APB1",
      "pins": {
        "TX": ["PA0/AF8", "PC10/AF8"],
        "RX": ["PA1/AF8", "PC11/AF8"]
      }
    },
    "UART5": {
      "bus": "APB1",
      "pins": {
        "TX": ["PC12/AF8", "PE8/AF8"],
        "RX": ["PD2/AF8", "PE7/AF8"]
      },
      "_note": "F446의 UART5에 PE7/PE8 추가"
    },
    "USART6": {
      "bus": "APB2",
      "pins": {
        "TX": ["PC6/AF8", "PG14/AF8"],
        "RX": ["PC7/AF8", "PG9/AF8"]
      }
    },
    "USB_OTG_FS": {
      "pins": {
        "DM": ["PA11/AF10"], "DP": ["PA12/AF10"],
        "VBUS": ["PA9/GPIO_INPUT"], "ID": ["PA10/AF10"]
      }
    },
    "USB_OTG_HS": {
      "pins": {
        "DM": ["PB14/AF12"], "DP": ["PB15/AF12"],
        "VBUS": ["PB13/GPIO_INPUT"], "ID": ["PB12/AF12"]
      },
      "_note": "내장 FS PHY 또는 외부 ULPI PHY"
    },
    "CAN1": {
      "bus": "APB1",
      "pins": {
        "TX": ["PA12/AF9", "PB9/AF9", "PD1/AF9"],
        "RX": ["PA11/AF9", "PB8/AF9", "PD0/AF9"]
      }
    },
    "CAN2": {
      "bus": "APB1",
      "pins": {
        "TX": ["PB6/AF9", "PB13/AF9"],
        "RX": ["PB5/AF9", "PB12/AF9"]
      }
    },
    "SDIO": {
      "bus": "APB2",
      "pins": {
        "CLK": ["PC12/AF12"], "CMD": ["PD2/AF12"],
        "D0": ["PC8/AF12"], "D1": ["PC9/AF12"],
        "D2": ["PC10/AF12"], "D3": ["PC11/AF12"]
      }
    },
    "DAC": {
      "pins": { "OUT1": ["PA4/ANALOG"], "OUT2": ["PA5/ANALOG"] }
    },
    "SAI1": {
      "af": 6,
      "_note": "Serial Audio Interface 1 — I2S/TDM/AC97 고음질 오디오"
    },
    "SAI2": {
      "af": 10,
      "_note": "Serial Audio Interface 2"
    },
    "QUADSPI": {
      "pins": {
        "CLK":  ["PB2/AF9", "PD3/AF9"],
        "BK1_NCS": ["PB6/AF10"],
        "BK1_IO0": ["PC9/AF9", "PD11/AF9"],
        "BK1_IO1": ["PC10/AF9", "PD12/AF9"],
        "BK1_IO2": ["PE2/AF9"],
        "BK1_IO3": ["PA1/AF9", "PD13/AF9"]
      },
      "_note": "Quad-SPI Flash 인터페이스 — F446 전용"
    },
    "DCMI":  { "af": 13 },
    "FMC":   { "af": 12 }
  },

  "adc_pins": [
    "PA0/ADC123_IN0", "PA1/ADC123_IN1", "PA2/ADC123_IN2", "PA3/ADC123_IN3",
    "PA4/ADC12_IN4",  "PA5/ADC12_IN5",  "PA6/ADC12_IN6",  "PA7/ADC12_IN7",
    "PB0/ADC12_IN8",  "PB1/ADC12_IN9",
    "PC0/ADC123_IN10","PC1/ADC123_IN11","PC2/ADC123_IN12","PC3/ADC123_IN13",
    "PC4/ADC12_IN14", "PC5/ADC12_IN15"
  ],

  "five_volt_tolerant": [
    "PA0","PA1","PA2","PA3","PA5","PA6","PA7","PA8","PA9","PA10","PA11","PA12","PA13","PA14","PA15",
    "PB0","PB1","PB2","PB3","PB4","PB5","PB6","PB7","PB8","PB9","PB10","PB11","PB12","PB13","PB14","PB15",
    "PC6","PC7","PC8","PC9","PC10","PC11","PC12","PC13","PC14","PC15",
    "PD0","PD1","PD2","PD3","PD4","PD5","PD6","PD7","PD8","PD9","PD10","PD11","PD12","PD13","PD14","PD15",
    "PE0","PE1","PE2","PE3","PE4","PE5","PE6","PE7","PE8","PE9","PE10","PE11","PE12","PE13","PE14","PE15"
  ],
  "not_five_volt_tolerant": [
    "PA4", "PC0", "PC1", "PC2", "PC3", "PC4", "PC5", "PH0", "PH1"
  ],

  "special_pins": {
    "BOOT0": "전용핀 — GND로 풀다운 필요",
    "PA13": "SWDIO", "PA14": "SWCLK", "PB3": "SWO",
    "PA0":  "WKUP1", "PH0": "OSC_IN", "PH1": "OSC_OUT",
    "PA11": "USB_FS_DM / CAN1_RX — 동시 사용 불가",
    "PA12": "USB_FS_DP / CAN1_TX — 동시 사용 불가",
    "PB2":  "BOOT1 / QUADSPI_CLK — BOOT 간섭 주의"
  },

  "pin_conflicts": [
    {
      "pins": ["PA11", "PA12"],
      "functions": ["USB_OTG_FS", "CAN1"],
      "severity": "ERROR",
      "resolution": "CAN1을 PB8/PB9 또는 PD0/PD1로 이동"
    },
    {
      "pins": ["PA4", "PA5"],
      "functions": ["DAC", "SPI1_NSS/SCK"],
      "severity": "ERROR",
      "resolution": "DAC 사용 시 SPI1을 PB3/PB4/PB5로 이동"
    },
    {
      "pins": ["PA9"],
      "functions": ["USART1_TX", "SPI2_SCK"],
      "severity": "ERROR",
      "resolution": "F446에서 PA9는 SPI2_SCK(AF5)와 USART1_TX(AF7) 겸용, 하나만 선택"
    },
    {
      "pins": ["PC10", "PC11", "PC12"],
      "functions": ["USART3", "SPI3", "SDIO", "UART4"],
      "severity": "ERROR",
      "resolution": "최대 1개 페리페럴만 사용, 나머지는 다른 핀으로"
    },
    {
      "pins": ["PB2"],
      "functions": ["BOOT1", "QUADSPI_CLK"],
      "severity": "WARN",
      "resolution": "QUADSPI 사용 시 BOOT1 외부 풀다운 필수"
    }
  ]
}
